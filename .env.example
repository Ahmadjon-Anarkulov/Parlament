# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=MyParlamentBot
BOT_MODE=long_polling          # long_polling | webhook

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_USER=postgres
DATABASE_PASSWORD=your_strong_password_here

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs who get admin access
ADMIN_IDS=123456789,987654321

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@parlament.uz
PGADMIN_PASSWORD=admin123

# ─── Webhook (only needed if BOT_MODE=webhook) ───────────────────────────────
BOT_WEBHOOK_PUBLIC_URL=https://your-domain.railway.app
BOT_WEBHOOK_PATH=/telegram/webhook
