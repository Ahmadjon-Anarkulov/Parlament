## Telegram bot
BOT_TOKEN=replace_me
BOT_USERNAME=replace_me

## Mode
BOT_MODE=long_polling

## Webhook (optional)
BOT_WEBHOOK_ENABLED=false
BOT_WEBHOOK_PUBLIC_URL=https://your-service.up.railway.app
BOT_WEBHOOK_PATH=/telegram/webhook
BOT_WEBHOOK_SECRET_TOKEN=

## Spring
PORT=8080
LOG_LEVEL_ROOT=INFO

